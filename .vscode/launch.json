{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "RA8D1 probe-rs GDB attach",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/ra8d1_eit.elf",
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "miDebuggerPath": "arm-none-eabi-gdb",
      "miDebuggerServerAddress": "127.0.0.1:1337",
      "preLaunchTask": "probe-rs: gdb-server",
      "launchCompleteCommand": "None",
      "setupCommands": [
        {
          "description": "Enable GDB pretty printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Use hardware breakpoints by default",
          "text": "set breakpoint auto-hw on",
          "ignoreFailures": true
        },
        {
          "description": "Reset and halt after connection",
          "text": "monitor reset halt",
          "ignoreFailures": true
        },
        {
          "description": "Load program image",
          "text": "load",
          "ignoreFailures": true
        },
        {
          "description": "Stop in hal_entry",
          "text": "break hal_entry",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
